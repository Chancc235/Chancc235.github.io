{% if jekyll.environment == "development" and site.preview_prefix %}
  {% assign base_path = site.preview_prefix | append: site.baseurl %}
{% elsif jekyll.environment == "development" %}
  {% assign base_path = site.baseurl %}
{% elsif site.url %}
  {% assign base_path = site.url | append: site.baseurl %}
{% else %}
  {% assign base_path = site.github.url %}
{% endif %}
